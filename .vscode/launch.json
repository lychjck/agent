{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug stock_assistant",
            "type": "debugpy",
            "request": "launch",
            "python": "${workspaceFolder}/.venv/bin/python",
            "program": "${workspaceFolder}/stock_assistant.py",
            "args": [
                "--config",
                "config.toml",
                "run"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": false
        }
    ]
}